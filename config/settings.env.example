# ── LLM 配置 ────────────────────────────────────
# 注意：模型名称应与实际使用的 deepseek 模型一致
LLM_MODEL=deepseek-v4-flash
LLM_API_KEY=your-llm-api-key-here
LLM_API_BASE=https://api.deepseek.com

# ── 威胁情报配置 ─────────────────────────────
# VirusTotal API Key（可选，不配置则使用模拟查询）
# 申请地址：https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your-virustotal-api-key-here

# AlienVault OTX API Key（可选）
OTX_API_KEY=your-otx-api-key-here

# 微步在线 API Key（可选）
MICROSTEP_API_KEY=your-microstep-api-key-here

# ── 运行配置 ────────────────────────────────────
# 输出目录
OUTPUT_DIR=./output

# 白名单数据目录
WHITELIST_DATA_DIR=./skills/whitelist_filter/data

# 日志级别：DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
